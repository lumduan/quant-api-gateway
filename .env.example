# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Storage — provisioned by quant-infra-db on the quant-network
POSTGRES_DSN=postgresql://postgres:<pass>@quant-postgres:5432/db_gateway
MONGO_URI=mongodb://quant-mongo:27017/
REDIS_URL=redis://quant-redis:6379/0

# Upstream Strategy Services
CSM_SET_SERVICE_URL=http://quant-csm-set:8001

# Inter-service authentication
INTERNAL_API_KEY=your_strong_internal_key_here

# Observability
LOG_LEVEL=INFO

# Docker — host-side port published by docker-compose.yml. Container
# port is always 8000. Override to 8080 (or anything free) when another
# service on the host already binds 8000 — e.g. the upstream
# quant-csm-set Strategy Service.
API_GATEWAY_HOST_PORT=8000

# Optional: override the strategy registry file path. Defaults to
# `strategies.json` at the working directory (the container ships it at /app).
# STRATEGY_REGISTRY_PATH=strategies.json
